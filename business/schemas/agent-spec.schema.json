{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://generic-swarm-ops.local/schemas/agent-spec.schema.json",
  "title": "AgentSpec",
  "type": "object",
  "required": [
    "id",
    "domain_id",
    "name",
    "status",
    "requires_alc",
    "allowed_memory_scopes",
    "alc_version"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "va_id": { "type": "integer" },
    "domain_id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "role": { "type": "string" },
    "category": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["draft", "registered", "active", "disabled"]
    },
    "requires_alc": { "type": "boolean" },
    "allowed_memory_scopes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["agent", "organization", "run", "workflow", "public"]
      }
    },
    "alc_version": { "type": "string", "minLength": 1 },
    "hooks": {
      "type": "object",
      "properties": {
        "reflect": { "type": "boolean" }
      }
    },
    "tools": {
      "type": "array",
      "items": { "type": "string" }
    },
    "risk_tier": { "type": "string" },
    "critique_rubric_ref": { "type": ["string", "null"] },
    "provenance": { "type": "object" }
  },
  "additionalProperties": true
}
