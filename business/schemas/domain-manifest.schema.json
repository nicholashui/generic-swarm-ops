{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://generic-swarm-ops.local/schemas/domain-manifest.schema.json",
  "title": "DomainPackManifest",
  "type": "object",
  "required": [
    "domain_id",
    "version",
    "display_name",
    "requires_alc",
    "agents",
    "workflows"
  ],
  "properties": {
    "domain_id": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "display_name": { "type": "string", "minLength": 1 },
    "default_risk_tier": {
      "type": "string",
      "enum": [
        "tier_0_observe",
        "tier_1_recommend",
        "tier_2_draft",
        "tier_3_execute_reversible",
        "tier_4_execute_with_gate",
        "tier_5_restricted"
      ]
    },
    "requires_alc": { "type": "boolean" },
    "agents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          { "type": "string", "minLength": 1 },
          {
            "type": "object",
            "required": ["id"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "path": { "type": "string" }
            }
          }
        ]
      }
    },
    "workflows": {
      "type": "array",
      "items": {
        "oneOf": [
          { "type": "string" },
          {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "path": { "type": "string" }
            }
          }
        ]
      }
    },
    "knowledge_seed_globs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "api_hooks": {
      "type": "object",
      "properties": {
        "on_register": { "type": "string" },
        "tool_namespace": { "type": "string" }
      }
    },
    "provenance": { "type": "object" }
  },
  "additionalProperties": true
}
