# Copy to backend/.env and fill in real values (never commit .env)

# Database (Postgres) — used by RuntimeStore when GENERIC_SWARM_FORCE_JSON_STORE is not true
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@localhost:5432/gsodb
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=5
DATABASE_POOL_PRE_PING=true

# Optional: force JSON file store even if DATABASE_URL is set (tests/offline)
# GENERIC_SWARM_FORCE_JSON_STORE=false

# Optional: /health/ready returns 503 unless store is Postgres and reachable
# GENERIC_SWARM_REQUIRE_POSTGRES=false

# Self-improvement
# GENERIC_SWARM_AUTO_REFLECT=true
# GENERIC_SWARM_LLM_CRITIC_ENABLED=false
# GENERIC_SWARM_LLM_API_BASE=http://127.0.0.1:11434/v1
# GENERIC_SWARM_LLM_API_KEY=local
# GENERIC_SWARM_LLM_MODEL=gpt-4o-mini

# Embeddings / optional pgvector table
# GENERIC_SWARM_EMBEDDINGS_ENABLED=true
# GENERIC_SWARM_PGVECTOR_ENABLED=false

# Neo4j federation (optional bolt push)
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=

# Browser CORS (required when frontend uses credentials; never use * alone)
# GENERIC_SWARM_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

